   "source": [
    "# Notebook 3: Data Preparation\n",
    "\n",
    "This notebook handles data cleaning, normalization, and preparation for model training.\n",
    "\n",
    "## 3.1 Setup and Imports"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import re\n",
    "import os\n",
    "import json\n",
    "from collections import Counter\n",
    "\n",
    "WORK_DIR = \"/home/kwierman/Desktop/Projects/DeepPastAkkadian\"\n",
    "os.chdir(WORK_DIR)\n",
    "\n",
    "# Load data\n",
    "train_df = pd.read_csv(\"train.csv\")\n",
    "test_df = pd.read_csv(\"test.csv\")\n",
    "\n",
    "print(f\"Train shape: {train_df.shape}\")\n",
    "print(f\"Test shape: {test_df.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3.2 Text Normalization Functions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def normalize_akkadian(text):\n",
    "    \"\"\"\n",
    "    Normalize Akkadian transliteration text according to DATA.md guidelines.\n",
    "    \n",
    "    Key normalizations:\n",
    "    - Ḫ → H (critical: train has Ḫ, test has H)\n",
    "    - ḫ → h\n",
    "    - Remove scribal notations: !, ?, /, :, .\n",
    "    - Remove partially broken signs: ˹ ˺\n",
    "    - Remove square brackets content: [ ]\n",
    "    - Keep gap markers: <gap>, <big_gap>\n",
    "    - Handle determinatives: {d}, {ki}, etc. - keep but clean\n",
    "    \"\"\"\n",
    "    if pd.isna(text):\n",
    "        return \"\"\n",
    "    \n",
    "    text = str(text)\n",
    "    \n",
    "    # Critical: Normalize H characters (Ḫ→H, ḫ→h)\n",
    "    text = text.replace('Ḫ', 'H').replace('ḫ', 'h')\n",
    "    \n",
    "    # Remove scribal notations (keep content inside < > for insertions)\n",
    "    text = re.sub(r'[!?]', '', text)  # Certain/questionable reading\n",
    "    text = re.sub(r'/', '', text)       # Line divider\n",
    "    text = re.sub(r':', ' ', text)      # Word divider -> space\n",
    "    text = re.sub(r'\\.', ' ', text)      # Word divider -> space\n",
    "    \n",
    "    # Remove partially broken signs\n",
    "    text = re.sub(r'[˹˺]', '', text)\n",
    "    \n",
    "    # Clean square brackets - remove content but keep gap markers\n",
    "    # [x] -> <gap>\n",
    "    text = re.sub(r'\\[x\\]', '<gap>', text)\n",
    "    # [...] or [... …] -> <big_gap>\n",
    "    text = re.sub(r'\\[[^\\]]*\\]', '<big_gap>', text)\n",
    "    \n",
    "    # Clean up extra whitespace\n",
    "    text = re.sub(r'\\s+', ' ', text)\n",
    "    text = text.strip()\n",
    "    \n",
    "    return text\n",
    "\n",
    "\n",
    "def normalize_translation(text):\n",
    "    \"\"\"\n",
    "    Normalize English translation text.\n",
    "    \n",
    "    Similar cleaning but less aggressive since translation is already in English.\n",
    "    \"\"\"\n",
    "    if pd.isna(text):\n",
    "        return \"\"\n",
    "    \n",
    "    text = str(text)\n",
    "    \n",
    "    # Remove extra quotes that may have been introduced\n",
    "    text = text.replace('\"\"\"\"', '\"').replace('\"\"\"', '\"').replace('\"\"', '\"')\n",
    "    \n",
    "    # Clean up whitespace\n",
    "    text = re.sub(r'\\s+', ' ', text)\n",
    "    text = text.strip()\n",
    "    \n",
    "    return text\n",
    "\n",
    "print(\"Normalization functions defined.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test normalization on sample texts\n",
    "sample_text = \"um-ma kà-ru-um kà-ni-ia-ma a-na aa-qí-il… da-tim[a-lim{ki}] aì-ip-ri-ni!\"\n",
    "print(f\"Original: {sample_text}\")\n",
    "print(f\"Normalized: {normalize_akkadian(sample_text)}\")\n",
    "\n",
    "print(\"\\n\")\n",
    "\n",
    "# Test with H character\n",
    "sample_h = \"a-šùr-{d}UTU Ḫa-ma-tim\"\n",
    "print(f\"Original H: {sample_h}\")\n",
    "print(f\"Normalized H: {normalize_akkadian(sample_h)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3.3 Apply Normalization"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Apply normalization to training data\n",
    "train_df['transliteration_norm'] = train_df['transliteration'].apply(normalize_akkadian)\n",
    "train_df['translation_norm'] = train_df['translation'].apply(normalize_translation)\n",
    "\n",
    "# Apply normalization to test data\n",
    "test_df['transliteration_norm'] = test_df['transliteration'].apply(normalize_akkadian)\n",
    "\n",
    "print(\"Normalization applied.\")\n",
    "\n",
    "# Compare before/after\n",
    "print(\"\\n\" + \"=\" * 60)\n",
    "print(\"Sample normalization (train):\")\n",
    "print(\"=\" * 60)\n",
    "for i in range(3):\n",
    "    print(f\"\\n--- Sample {i+1} ---\")\n",
    "    print(f\"BEFORE: {train_df.iloc[i]['transliteration'][:100]}...\")\n",
    "    print(f\"AFTER:  {train_df.iloc[i]['transliteration_norm'][:100]}...\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3.4 Sentence-Level Processing"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Check if we need sentence-level alignment\n",
    "# Training data is document-level, test is sentence-level\n",
    "\n",
    "print(\"=\" * 60)\n",
    "print(\"TRAIN vs TEST ALIGNMENT CHECK\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "# Check test data structure\n",
    "print(f\"\\nTest columns: {test_df.columns.tolist()}\")\n",
    "print(f\"Test unique text_ids: {test_df['text_id'].nunique()}\")\n",
    "print(f\"Test has line_start/line_end: {'line_start' in test_df.columns}\")\n",
    "\n",
    "# Check sample submission format\n",
    "sample_sub = pd.read_csv(\"sample_submission.csv\")\n",
    "print(f\"\\nSample submission columns: {sample_sub.columns.tolist()}\")\n",
    "print(f\"Sample submission shape: {sample_sub.shape}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Since test is sentence-level, we need to ensure training can be used effectively\n",
    "# The model will be trained on document-level pairs but needs to predict sentences\n",
    "\n",
    "# Let's also check if we can extract more training data from publications.csv\n",
    "print(\"Checking for additional training data extraction potential...\")\n",
    "\n",
    "try:\n",
    "    published_texts = pd.read_csv(\"published_texts.csv\")\n",
    "    print(f\"Published texts: {published_texts.shape}\")\n",
    "    print(f\"Columns: {published_texts.columns.tolist()[:10]}...\")\n",
    "    \n",
    "    # Check for transliteration column\n",
    "    if 'transliteration' in published_texts.columns:\n",
    "        print(f\"Transliterations available: {published_texts['transliteration'].notna().sum()}\")\n",
    "except Exception as e:\n",
    "    print(f\"Could not load published_texts: {e}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3.5 Create Training Datasets"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create clean training dataframe\n",
    "train_clean = train_df[['oare_id', 'transliteration_norm', 'translation_norm']].copy()\n",
    "train_clean.columns = ['id', 'source', 'target']\n",
    "\n",
    "# Remove empty rows\n",
    "train_clean = train_clean[train_clean['source'].str.len() > 0]\n",
    "train_clean = train_clean[train_clean['target'].str.len() > 0]\n",
    "\n",
    "print(f\"Clean training samples: {len(train_clean)}\")\n",
    "\n",
    "# Create test dataframe\n",
    "test_clean = test_df[['id', 'transliteration_norm']].copy()\n",
    "test_clean.columns = ['id', 'source']\n",
    "\n",
    "print(f\"Clean test samples: {len(test_clean)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Split into train/validation for model training\n",
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "# Stratified split based on source length bins\n",
    "train_clean['length_bin'] = pd.cut(train_clean['source'].str.len(), bins=10, labels=False)\n",
    "\n",
    "train_data, val_data = train_test_split(\n",
    "    train_clean, \n",
    "    test_size=0.1, \n",
    "    random_state=42,\n",
    "    stratify=train_clean['length_bin']\n",
    ")\n",
    "\n",
    "print(f\"Training set: {len(train_data)}\")\n",
    "print(f\"Validation set: {len(val_data)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3.6 Save Prepared Datasets"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create output directory\n",
    "os.makedirs(\"data/processed\", exist_ok=True)\n",
    "\n",
    "# Save as CSV for model training\n",
    "train_data.to_csv(\"data/processed/train.csv\", index=False)\n",
    "val_data.to_csv(\"data/processed/val.csv\", index=False)\n",
    "test_clean.to_csv(\"data/processed/test.csv\", index=False)\n",
    "\n",
    "# Also save full cleaned training data\n",
    "train_clean.to_csv(\"data/processed/train_full.csv\", index=False)\n",
    "\n",
    "print(\"Datasets saved to data/processed/\")\n",
    "print(f\"  - train.csv: {len(train_data)} samples\")\n",
    "print(f\"  - val.csv: {len(val_data)} samples\")\n",
    "print(f\"  - test.csv: {len(test_clean)} samples\")\n",
    "print(f\"  - train_full.csv: {len(train_clean)} samples\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save normalization config for inference\n",
    "normalization_config = {\n",
    "    \"normalization_rules\": [\n",
    "        \"Ḫ → H\",\n",
    "        \"ḫ → h\",\n",
    "        \"! ? → removed\",\n",
    "        \"/ → removed\",\n",
    "        \": . → space\",\n",
    "        \"˹ ˺ → removed\",\n",
    "        \"[x] → <gap>\",\n",
    "        \"[...] → <big_gap>\"\n",
    "    ],\n",
    \"train_samples\": len(train_data),\n",
    "val_samples\": len(val_data),\n",
    "test_samples\": len(test_clean)\n",
    "}\n",
    "\n",
    "with open(\"data/processed/normalization_config.json\", \"w\") as f:\n",
    "    json.dump(normalization_config, f, indent=2)\n",
    "\n",
    "print(\"Normalization config saved.\")"
   ]
  },
